---
import ThemeToggle from './ThemeToggle';
const { active = "Home" } = Astro.props;

const items = [
    { name: "Catalog", href: "/products", tooltip: "Where the magic happens" },
    { name: "Smooth Search", href: "/products/smooth-search", tooltip: "Speed of Rust, comfort of your couch" },
    { name: "Documentation", href: "/documentation", tooltip: "Read the manual (yes, really)" },
    { name: "Support", href: "/support", tooltip: "Need help? We got you" },
    { name: "About", href: "/about", tooltip: "Who we are and why we care" },
    { name: "Blog", href: "/blog", tooltip: "We write, you procrastinate" },
];
---

<nav class="nav" id="nav" aria-label="Main navigation">
    <a href="/" class="nav-logo">
        <div class="nav-logo-dot"></div>
        <span class="nav-logo-text">Smooth Plugins</span>
    </a>

    <div class="nav-links" id="nav-links">
        {items.map((item) => (
            <a
                href={item.href}
                class={`nav-link ${active === item.name ? 'active' : ''}`}
                data-tooltip={item.tooltip}
            >
                {item.name}
            </a>
        ))}
    </div>

    <div class="nav-actions">
        <ThemeToggle client:load />
    </div>

    <button class="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span class="nav-hamburger-line"></span>
        <span class="nav-hamburger-line"></span>
        <span class="nav-hamburger-line"></span>
    </button>

    <div class="nav-overlay"></div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const hamburger = document.querySelector('.nav-hamburger');
        const navLinks = document.getElementById('nav-links');
        const overlay = document.querySelector('.nav-overlay');
        const nav = document.getElementById('nav');
        const linkItems = document.querySelectorAll('.nav-link');

        function toggleMenu() {
            const isOpen = hamburger?.getAttribute('aria-expanded') === 'true';
            hamburger?.setAttribute('aria-expanded', String(!isOpen));
            hamburger?.classList.toggle('active');
            navLinks?.classList.toggle('mobile-open');
            overlay?.classList.toggle('active');
            document.body.style.overflow = isOpen ? '' : 'hidden';
        }

        hamburger?.addEventListener('click', toggleMenu);
        overlay?.addEventListener('click', toggleMenu);

        linkItems.forEach(item => {
            item.addEventListener('click', () => {
                if (navLinks?.classList.contains('mobile-open')) {
                    toggleMenu();
                }
            });
        });

        let ticking = false;
        window.addEventListener('scroll', () => {
            if (!ticking) {
                requestAnimationFrame(() => {
                    if (window.scrollY > 20) {
                        nav?.classList.add('scrolled');
                    } else {
                        nav?.classList.remove('scrolled');
                    }
                    ticking = false;
                });
                ticking = true;
            }
        }, { passive: true });
    });
</script>

<style>
    .nav {
        grid-column: 1 / -1;
        display: flex;
        align-items: center;
        padding: 3px;
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--c-surface);
        border-radius: 0 0 var(--radius-md) var(--radius-md);
        box-shadow: 0 10px 30px var(--c-shadow);
        transition: box-shadow 0.4s var(--ease-smooth);
        height: fit-content;
        opacity: 0.8;
    }

    .nav.scrolled {
        box-shadow: 0 12px 40px var(--c-shadow),
                    0 0 0 1px var(--c-border);
    }

    .nav-logo {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: var(--c-text-primary);
        font-family: var(--font-display);
        font-weight: var(--weight-bold);
        font-size: 1rem;
        letter-spacing: var(--tracking-tight);
        padding: 6px 12px;
        border-radius: var(--radius-pill);
        transition: background-color 0.2s var(--ease-smooth);
        flex-shrink: 0;
    }

    .nav-logo:hover {
        background-color: var(--c-bg);
    }

    .nav-logo-dot {
        width: 10px;
        height: 10px;
        background-color: var(--c-text-primary);
        border-radius: 50%;
        flex-shrink: 0;
        transition: transform 0.4s var(--ease-smooth),
                    background-color 0.3s var(--ease-smooth),
                    box-shadow 0.3s var(--ease-smooth);
    }

    .nav-logo:hover .nav-logo-dot {
        transform: scale(1.3);
        background-color: var(--c-lavender);
        box-shadow: 0 0 12px var(--c-logo-dot-shadow);
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 2px;
        flex: 1;
        justify-content: center;
    }

    .nav-link {
        padding: 6px 14px;
        text-decoration: none;
        color: var(--c-text-primary);
        font-family: var(--font-body);
        font-weight: var(--weight-medium);
        font-size: 0.875rem;
        border-radius: var(--radius-pill);
        transition: background-color 0.3s var(--ease-smooth),
                    color 0.3s var(--ease-smooth);
        position: relative;
        white-space: nowrap;
    }

    .nav-link:hover {
        background-color: var(--c-bg);
    }

    .nav-link.active {
        background-color: var(--c-primary);
        color: var(--c-primary-inverse);
    }

    .nav-link[data-tooltip]::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: -50px;
        left: 50%;
        transform: translateX(-50%) translateY(-8px);
        background: var(--tooltip-bg);
        color: var(--tooltip-text);
        padding: 10px 16px;
        border-radius: 10px;
        font-family: var(--font-body);
        font-size: var(--text-xs);
        font-weight: var(--weight-medium);
        white-space: nowrap;
        z-index: 1000;
        pointer-events: none;
        opacity: 0;
        box-shadow: 0 4px 20px var(--tooltip-shadow),
                    0 0 0 1px var(--tooltip-border),
                    var(--tooltip-glow, none);
        backdrop-filter: blur(12px);
        transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                    transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-link[data-tooltip]::before {
        content: '';
        position: absolute;
        bottom: -8px;
        left: 50%;
        transform: translateX(-50%) translateY(-8px);
        width: 0;
        height: 0;
        border-left: 6px solid transparent;
        border-right: 6px solid transparent;
        border-bottom: 6px solid var(--tooltip-arrow);
        z-index: 1001;
        pointer-events: none;
        opacity: 0;
        filter: drop-shadow(0 -2px 4px var(--tooltip-shadow))
                drop-shadow(var(--tooltip-arrow-glow, 0 0 0 transparent));
        transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                    transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-link[data-tooltip]:hover::after,
    .nav-link[data-tooltip]:hover::before {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
        transition-delay: 0.15s;
    }

    .nav-actions {
        display: flex;
        align-items: center;
        padding-left: 6px;
        margin-left: 2px;
        border-left: 1px solid var(--c-border);
        flex-shrink: 0;
    }

    .nav-actions :global(.theme-toggle) {
        width: 32px;
        height: 32px;
    }

    .nav-actions :global(.theme-toggle svg) {
        width: 16px;
        height: 16px;
    }

    .nav-hamburger {
        display: none;
        flex-direction: column;
        gap: 6px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        z-index: 102;
        transition: transform 0.3s var(--ease-smooth);
    }

    .nav-hamburger:hover {
        transform: scale(1.1);
    }

    .nav-hamburger-line {
        width: 24px;
        height: 2px;
        background-color: var(--c-text-primary);
        border-radius: 1px;
        transition: all 0.3s var(--ease-smooth);
    }

    .nav-hamburger.active .nav-hamburger-line:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
    }

    .nav-hamburger.active .nav-hamburger-line:nth-child(2) {
        opacity: 0;
        transform: translateX(-16px);
    }

    .nav-hamburger.active .nav-hamburger-line:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
    }

    .nav-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s var(--ease-smooth);
        z-index: 98;
    }

    .nav-overlay.active {
        opacity: 1;
        pointer-events: all;
    }

    @media (max-width: 768px) {
        .nav {
            border-radius: 0;
            box-shadow: none;
            padding: 10px 16px;
            justify-content: space-between;
        }

        .nav.scrolled {
            box-shadow: none;
        }

        .nav-links {
            position: fixed;
            top: 0;
            right: 0;
            height: 100vh;
            width: min(320px, 85vw);
            flex-direction: column;
            gap: 0;
            padding: 100px 32px 32px;
            background: var(--c-surface);
            border-radius: 0;
            box-shadow: -10px 0 40px var(--c-shadow);
            transform: translateX(100%);
            transition: transform 0.4s var(--ease-smooth);
            z-index: 99;
            overflow-y: auto;
            justify-content: flex-start;
        }

        .nav-links.mobile-open {
            transform: translateX(0);
        }

        .nav-hamburger {
            display: flex;
        }

        .nav-overlay {
            display: block;
        }

        .nav-link {
            width: 100%;
            padding: 14px 16px;
            font-size: var(--text-base);
            border-radius: var(--radius-md);
            text-align: left;
            opacity: 0;
            transform: translateX(20px);
            transition: all 0.3s var(--ease-smooth);
        }

        .nav-links.mobile-open .nav-link {
            opacity: 1;
            transform: translateX(0);
        }

        .nav-links.mobile-open .nav-link:nth-child(1) { transition-delay: 0.1s; }
        .nav-links.mobile-open .nav-link:nth-child(2) { transition-delay: 0.15s; }
        .nav-links.mobile-open .nav-link:nth-child(3) { transition-delay: 0.2s; }
        .nav-links.mobile-open .nav-link:nth-child(4) { transition-delay: 0.25s; }
        .nav-links.mobile-open .nav-link:nth-child(5) { transition-delay: 0.3s; }
        .nav-links.mobile-open .nav-link:nth-child(6) { transition-delay: 0.35s; }

        .nav-link[data-tooltip]::after,
        .nav-link[data-tooltip]:hover::after,
        .nav-link[data-tooltip]::before,
        .nav-link[data-tooltip]:hover::before {
            display: none;
        }

        .nav-actions {
            border-left: none;
            padding-left: 0;
            margin-left: 0;
        }
    }

    @media (max-width: 480px) {
        .nav-links {
            width: 100vw;
            right: 0;
            padding: 80px 24px 24px;
        }
    }
</style>

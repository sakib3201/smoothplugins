---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Card from '../../components/Card.astro';
import BackgroundCanvas from '../../components/BackgroundCanvas';
import Footer from '../../components/Footer.astro';
---

<Layout title="Products" description="Explore our catalog of high-performance WordPress plugins. From WebAssembly-powered search to innovative e-commerce solutions built with Rust.">
    <BackgroundCanvas client:only="react" />
    <div class="layout-container">
        <Navigation active="Catalog" />

        <div class="products-header">
            <h1>Our Plugin Catalog</h1>
            <p>High-performance WordPress plugins that actually respect your server.</p>
        </div>

        <Card
            title="Smooth Search"
            kicker="Available Now"
            description="The first WooCommerce search engine powered by WebAssembly. Sub-10ms queries. Zero server database load."
            variant="peach"
            span={8}
            class="product-card"
        >
            <div class="product-card-content">
                <p class="product-desc">Handles <strong>100,000+ products</strong> with <strong>&lt;10ms</strong> query time and zero database calls per search. Runs entirely in the browser via Rust-compiled WebAssembly.</p>
                <div class="product-badges">
                    <span class="tech-badge">Rust</span>
                    <span class="tech-badge">WASM32</span>
                    <span class="tech-badge">&lt;10ms queries</span>
                    <span class="tech-badge">100K+ products</span>
                </div>
                <a href="/products/smooth-search" class="product-cta">
                    View Details
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
        </Card>

        <Card
            title="More Amazing Plugins"
            kicker="In Development"
            variant="lavender"
            span={4}
            class="coming-soon-card"
        >
            <div class="coming-soon-content">
                <div class="construction-emoji">🚧</div>
                <p class="coming-soon-text">Our Rust engineers are currently caffeinating themselves to bring you more performance wizardry.</p>
                <div class="progress-bar">
                    <div class="progress-fill"></div>
                </div>
                <p class="progress-label">Compiling awesomeness...</p>
            </div>
        </Card>

        <Card
            title="More Plugins in Development"
            kicker="What's Next"
            variant="white"
            span={12}
            class="message-card"
        >
            <div class="message-content">
                <p class="message-text">
                    Smooth Search is the first in a focused set of performance plugins for WordPress. The same architectural approach — moving computation off the server using Rust and WebAssembly — applies to other WooCommerce and WordPress bottlenecks we're working on.
                </p>
                <p class="message-text">
                    Star the repository to follow development, or use the notification link below to hear when new plugins ship. In the meantime, Smooth Search is production-ready and available now.
                </p>
                <div class="support-actions">
                    <a href="https://github.com/sakib3201/smoothplugins" target="_blank" rel="noopener noreferrer" class="support-link">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        Star on GitHub
                    </a>
                    <a href="https://github.com/sakib3201/smoothplugins/releases" target="_blank" rel="noopener noreferrer" class="support-link">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                        </svg>
                        View releases
                    </a>
                </div>
            </div>
        </Card>

        <Footer />
    </div>
</Layout>

<style>
    .products-header {
        grid-column: 1 / -1;
        padding: 40px 0;
    }

    .products-header h1 {
        font-size: var(--text-4xl);
        font-weight: var(--weight-bold);
        letter-spacing: var(--tracking-tight);
        line-height: var(--leading-tight);
        margin-bottom: 16px;
        font-family: var(--font-display);
    }

    .products-header p {
        font-size: 20px;
        color: var(--c-text-secondary);
        margin-top: 8px;
    }

    .product-card-content {
        display: flex;
        flex-direction: column;
        gap: 28px;
        margin-top: 24px;
    }

    .product-desc {
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        color: inherit;
        max-width: 60ch;
    }

    .product-desc strong {
        font-weight: var(--weight-bold);
    }

    .product-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .tech-badge {
        display: inline-block;
        padding: 5px 12px;
        background: rgba(17, 17, 17, 0.12);
        border: 1px solid rgba(17, 17, 17, 0.15);
        border-radius: var(--radius-pill);
        font-family: 'SF Mono', Monaco, 'Cascadia Code', Consolas, monospace;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.025em;
        color: inherit;
    }

    .product-cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--c-primary);
        color: var(--c-primary-inverse);
        padding: 16px 32px;
        border-radius: var(--radius-pill);
        font-weight: 600;
        font-size: 16px;
        transition: all 0.3s var(--ease-smooth);
        align-self: flex-start;
    }

    .product-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px var(--c-shadow);
    }

    .product-cta svg {
        transition: transform 0.3s var(--ease-smooth);
    }

    .product-cta:hover svg {
        transform: translateX(4px);
    }

    .coming-soon-card {
        min-height: 300px;
    }

    .coming-soon-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 20px;
        padding: 20px 0;
    }

    .construction-emoji {
        font-size: 64px;
        animation: presence 3s ease-in-out infinite;
    }

    @keyframes presence {
        0%, 100% { opacity: 0.75; }
        50% { opacity: 1; }
    }

    .coming-soon-text {
        font-size: 16px;
        line-height: 1.6;
        color: inherit;
        opacity: 0.8;
    }

    .progress-bar {
        width: 100%;
        height: 8px;
        background: var(--c-bg);
        border-radius: var(--radius-pill);
        overflow: hidden;
        margin-top: 8px;
    }

    .progress-fill {
        height: 100%;
        width: 42%;
        background: rgba(17, 17, 17, 0.25);
        border-radius: var(--radius-pill);
        animation: shimmer 2s ease-in-out infinite;
    }

    @keyframes shimmer {
        0% {
            opacity: 0.6;
        }
        50% {
            opacity: 1;
        }
        100% {
            opacity: 0.6;
        }
    }

    .progress-label {
        font-size: 12px;
        font-family: monospace;
        color: inherit;
        opacity: 0.7;
    }

    .message-content {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .message-text {
        font-size: 18px;
        line-height: 1.7;
        color: inherit;
        opacity: 0.85;
    }

    .support-actions {
        display: flex;
        gap: 16px;
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .support-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 24px;
        background: rgba(0, 0, 0, 0.05);
        border-radius: var(--radius-pill);
        font-weight: 600;
        font-size: 15px;
        color: inherit;
        transition: all 0.3s var(--ease-smooth);
        border: 1px solid currentColor;
        border-opacity: 0.2;
    }

    :global([data-theme="dark"]) .support-link {
        background: rgba(255, 255, 255, 0.1);
    }

    .support-link:hover {
        background: var(--c-primary);
        color: var(--c-primary-inverse);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px var(--c-shadow);
    }

    @media (max-width: 1024px) {
        .products-header p {
            font-size: 18px;
        }
    }

    @media (max-width: 640px) {
        .products-header {
            padding: 20px 0;
        }

        .products-header h1 {
            font-size: 36px;
            letter-spacing: -1px;
        }

        .products-header p {
            font-size: 16px;
        }

        .product-cta {
            width: 100%;
            justify-content: center;
            padding: 14px 24px;
            font-size: 15px;
        }

        .coming-soon-text {
            font-size: 15px;
        }

        .support-actions {
            flex-direction: column;
        }

        .support-link {
            width: 100%;
            justify-content: center;
            padding: 12px 20px;
            font-size: 14px;
        }

        .message-text {
            font-size: 16px;
        }
    }

    @media (max-width: 480px) {
        .products-header h1 {
            font-size: 32px;
        }

        .products-header p {
            font-size: 15px;
        }

        .message-text {
            font-size: 15px;
            line-height: 1.6;
        }
    }
</style>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import LiteFooter from '../../components/LiteFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
    const blogPosts = await getCollection('blog');
    return blogPosts.map(post => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const displayDate = post.data.date;
const isoDate = post.data.dateISO || new Date(displayDate).toISOString();

const readingMinutes = readingTime(post.body ?? '');

const articleSchema = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": isoDate,
    "dateModified": isoDate,
    "author": {
        "@type": "Person",
        "name": post.data.author || "Smooth Plugins Team"
    },
    "publisher": {
        "@type": "Organization",
        "name": "Smooth Plugins",
        "logo": {
            "@type": "ImageObject",
            "url": "https://smoothplugins.com/logo.png"
        }
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://smoothplugins.com/blog/${post.slug}`
    }
};
---

<Layout
    title={post.data.title}
    description={post.data.description}
    type="article"
    publishedTime={isoDate}
    author={post.data.author || "Smooth Plugins Team"}
>
    <div class="progress-bar" id="reading-progress" aria-hidden="true"></div>

    <div class="layout-container">
        <Navigation active="Blog" />

        <Breadcrumb
            items={[
                { name: "Blog", url: "/blog" },
                { name: post.data.title, url: `/blog/${post.slug}` }
            ]}
        />

        <article class="blog-post">
            <header class="post-header">
                <div class="post-meta-row">
                    <time class="post-meta-item" datetime={isoDate}>{post.data.date}</time>
                    <span class="meta-sep" aria-hidden="true">·</span>
                    <span class="post-meta-item">{readingMinutes} min read</span>
                    {post.data.author && (
                        <>
                            <span class="meta-sep" aria-hidden="true">·</span>
                            <span class="post-meta-item">{post.data.author}</span>
                        </>
                    )}
                </div>

                <h1 class="post-title">{post.data.title}</h1>
                <p class="post-description">{post.data.description}</p>
            </header>

            <div class="post-content">
                <Content />
            </div>

            <footer class="post-footer">
                <a href="/blog" class="back-link">← All articles</a>
            </footer>
        </article>

        <LiteFooter />
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</Layout>

<script>
    function initProgress() {
        const bar = document.getElementById('reading-progress');
        if (!bar) return;

        function update() {
            const scrolled = window.scrollY;
            const total = document.documentElement.scrollHeight - window.innerHeight;
            (bar as HTMLElement).style.width = total > 0 ? `${(scrolled / total) * 100}%` : '0%';
        }

        window.addEventListener('scroll', update, { passive: true });
        update();
    }

    initProgress();
    document.addEventListener('astro:page-load', initProgress);
</script>

<style>
    /* ── Reading progress bar ── */

    .progress-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0%;
        background: var(--c-lavender);
        z-index: 9999;
        pointer-events: none;
        will-change: width;
    }

    /* ── Article shell ── */

    .blog-post {
        grid-column: 1 / -1;
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 24px 96px;
    }

    /* ── Header ── */

    .post-header {
        margin-bottom: 52px;
        padding-bottom: 40px;
        border-bottom: 1px solid var(--c-border);
    }

    .post-meta-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .post-meta-item {
        font-family: 'SF Mono', Monaco, 'Cascadia Code', Consolas, monospace;
        font-size: 0.72rem;
        color: var(--c-text-secondary);
    }

    .meta-sep {
        color: var(--c-text-secondary);
        opacity: 0.35;
        font-size: 0.8rem;
        line-height: 1;
    }

    .post-title {
        font-family: var(--font-display);
        font-size: var(--text-4xl);
        font-weight: var(--weight-bold);
        letter-spacing: var(--tracking-tight);
        line-height: var(--leading-tight);
        color: var(--c-text-primary);
        margin-bottom: 20px;
        text-wrap: balance;
    }

    .post-description {
        font-family: var(--font-body);
        font-size: var(--text-lg);
        color: var(--c-text-secondary);
        line-height: 1.65;
        max-width: 58ch;
    }

    /* ── Body ── */

    .post-content {
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.85;
        color: var(--c-text-primary);
        font-kerning: normal;
        font-optical-sizing: auto;
    }

    .post-content :global(p) {
        margin-bottom: 1.5em;
        max-width: 68ch;
        text-wrap: pretty;
    }

    .post-content :global(h2) {
        font-family: var(--font-display);
        font-size: var(--text-2xl);
        font-weight: var(--weight-bold);
        letter-spacing: var(--tracking-tight);
        line-height: var(--leading-tight);
        color: var(--c-text-primary);
        margin-top: 2.5em;
        margin-bottom: 0.75em;
        text-wrap: balance;
    }

    .post-content :global(h3) {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: var(--weight-semibold);
        letter-spacing: -0.01em;
        line-height: var(--leading-snug);
        color: var(--c-text-primary);
        margin-top: 2em;
        margin-bottom: 0.6em;
        text-wrap: balance;
    }

    .post-content :global(ul),
    .post-content :global(ol) {
        padding-left: 1.5em;
        margin: 1.25em 0;
        max-width: 66ch;
    }

    .post-content :global(li) {
        margin-bottom: 0.5em;
        line-height: 1.7;
    }

    .post-content :global(strong) {
        font-weight: var(--weight-semibold);
    }

    .post-content :global(a) {
        color: var(--c-text-primary);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(0, 0, 0, 0.25);
        transition: text-decoration-color 0.15s ease;
    }

    :global([data-theme="dark"]) .post-content :global(a) {
        text-decoration-color: rgba(255, 255, 255, 0.25);
    }

    .post-content :global(a:hover) {
        text-decoration-color: var(--c-text-primary);
    }

    .post-content :global(code) {
        font-family: 'SF Mono', Monaco, 'Cascadia Code', Consolas, monospace;
        font-size: 0.875em;
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        padding: 2px 6px;
        border-radius: 4px;
        font-variant-ligatures: none;
    }

    .post-content :global(pre) {
        background: var(--c-primary);
        color: var(--c-primary-inverse);
        padding: 24px 28px;
        border-radius: 12px;
        overflow-x: auto;
        margin: 2em 0;
        font-variant-ligatures: none;
        line-height: 1.65;
    }

    .post-content :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.875rem;
        color: inherit;
    }

    .post-content :global(blockquote) {
        border-left: 2px solid var(--c-lavender);
        padding: 4px 0 4px 24px;
        margin: 2em 0;
        color: var(--c-text-secondary);
        font-style: italic;
    }

    .post-content :global(blockquote p) {
        margin-bottom: 0;
    }

    .post-content :global(hr) {
        border: none;
        border-top: 1px solid var(--c-border);
        margin: 2.5em 0;
    }

    .post-content :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 2em 0;
    }

    /* ── Footer ── */

    .post-footer {
        margin-top: 64px;
        padding-top: 32px;
        border-top: 1px solid var(--c-border);
    }

    .back-link {
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: var(--weight-semibold);
        color: var(--c-text-primary);
        text-decoration: none;
        transition: opacity 0.15s ease;
    }

    .back-link:hover {
        opacity: 0.55;
    }

    /* ── Responsive ── */

    @media (max-width: 768px) {
        .blog-post {
            padding: 32px 16px 72px;
        }

        .post-header {
            margin-bottom: 40px;
            padding-bottom: 32px;
        }

        .post-title {
            font-size: var(--text-3xl);
        }

        .post-description {
            font-size: var(--text-base);
        }

        .post-content {
            font-size: 1rem;
        }

        .post-content :global(h2) {
            font-size: var(--text-xl);
            margin-top: 2em;
        }

        .post-content :global(h3) {
            font-size: var(--text-lg);
        }

        .post-content :global(pre) {
            padding: 16px 20px;
            margin: 1.5em -16px;
            border-radius: 0;
        }
    }

    @media (max-width: 480px) {
        .post-title {
            font-size: var(--text-2xl);
        }

        .post-meta-row {
            gap: 6px;
        }

        .post-content :global(h2) {
            font-size: var(--text-lg);
        }
    }
</style>

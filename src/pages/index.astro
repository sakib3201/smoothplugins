---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Card from '../components/Card.astro';
import SmoothSearchDemo from '../components/SmoothSearchDemo';
import BackgroundCanvas from '../components/BackgroundCanvas';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';

// Homepage FAQ data for AI discoverability
const faqs = [
    {
        question: "What is Smooth Plugins?",
        answer: "Smooth Plugins builds high-performance WordPress plugins powered by Rust and WebAssembly. We focus on creating affordable software that delivers exceptional performance and frictionless user experiences for modern web platforms."
    },
    {
        question: "What is WebAssembly and why does it matter for WordPress?",
        answer: "WebAssembly (WASM) is a binary instruction format that runs at near-native speed in web browsers. For WordPress, this means moving heavy computations from your PHP server to the visitor's browser, dramatically reducing server load and improving response times. Our plugins use Rust compiled to WebAssembly for maximum performance."
    },
    {
        question: "How much faster is Rust compared to PHP?",
        answer: "Rust typically performs 10-100x faster than PHP for compute-intensive tasks like search indexing and data processing. More importantly, when compiled to WebAssembly and run in the browser, it eliminates server round-trips entirely, reducing response times from seconds to milliseconds."
    },
    {
        question: "Are Smooth Plugins compatible with my WordPress theme and other plugins?",
        answer: "Yes! Our plugins are designed as drop-in replacements that work seamlessly with existing WordPress themes and plugins. We maintain full compatibility with WordPress core functionality and WooCommerce features without requiring any code changes."
    },
    {
        question: "Why should I use WebAssembly instead of traditional WordPress plugins?",
        answer: "Traditional WordPress plugins run on your server, consuming resources and adding latency. WebAssembly plugins offload computation to the visitor's browser, resulting in: zero server database load, 200ms average response times, 80% reduction in server costs, and the ability to handle 10,000+ products effortlessly."
    },
    {
        question: "Is Smooth Plugins open source?",
        answer: "Yes! We believe in open collaboration. Our code is available on GitHub, and we welcome contributions from developers worldwide. You can view our repositories, report issues, and submit pull requests at <a href='https://github.com/sakib3201/smoothplugins'>github.com/sakib3201/smoothplugins</a>."
    },
    {
        question: "Do I need technical knowledge to use Smooth Plugins?",
        answer: "No technical expertise required! Our plugins install like any standard WordPress plugin - just upload, activate, and configure through the WordPress admin panel. The complex Rust and WebAssembly technology runs automatically in the background."
    },
    {
        question: "Will Smooth Plugins work on my hosting provider?",
        answer: "Absolutely! Since our plugins run in the visitor's browser via WebAssembly, they work on any hosting provider that supports WordPress. No special server configuration, no additional dependencies, no hosting requirements beyond basic WordPress compatibility."
    }
];

---

<Layout title="Home" description="Smooth Plugins builds high-performance WordPress plugins powered by Rust and WebAssembly. Experience lightning-fast search with zero server load.">
    <BackgroundCanvas client:only="react" />
	<div class="layout-container">
		<Navigation active="Home" />

		<section class="hero" id="hero">
			<div class="hero-content">
				<h1 class="hero-title">
					Performance<br/>
					<span class="hero-title-accent">Without</span><br/>
					Friction
				</h1>
				<div class="compile-status">
					<span class="status-dot"></span>
					<code id="compile-status-text" class="status-text"></code>
				</div>
				<p class="hero-subtitle">WordPress plugins built with Rust and WebAssembly. Search that runs in the browser — zero server load, instant results.</p>
				<div class="hero-actions">
					<a href="/products/smooth-search" class="hero-cta">
						Explore Smooth Search
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</a>
					<a href="#live-demo" class="hero-secondary-cta">See it in action</a>
				</div>
			</div>
		</section>

		<script>
			function initHeroStatus() {
				const el = document.getElementById('compile-status-text');
				if (!el) return;

				const text = 'wasm32-unknown-unknown \u2192 compiled in 0.8ms';
				const visited = sessionStorage.getItem('hero-compiled');
				const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const startDelay = reduced ? 100 : 1100;

				setTimeout(() => {
					if (visited) {
						el.textContent = text;
						return;
					}
					let i = 0;
					const step = () => {
						if (!el || i >= text.length) return;
						el.textContent = text.slice(0, i + 1);
						i++;
						setTimeout(step, 18 + Math.random() * 22);
						if (i >= text.length) sessionStorage.setItem('hero-compiled', '1');
					};
					step();
				}, startDelay);
			}

			initHeroStatus();
			document.addEventListener('astro:page-load', initHeroStatus);
		</script>

		<Card
            title="Search at the speed of Rust."
            kicker="New Release: Smooth Search"
            description="The first WooCommerce search engine powered by WebAssembly. Blazing fast indexing and retrieval directly in the browser."
            variant="peach"
            span={8}
            class="hero-card"
        >
            <a href="/products/smooth-search" class="cta-button">
                Explore Smooth Search
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </Card>

        <Card title="200ms" kicker="Response Time" variant="white" span={4} class="stat-card">
            <p class="stat-label">Average per query</p>
            <p class="feature-desc">Your shoppers see results as they type — no waiting, no page reloads, no visible latency.</p>
        </Card>

        <Card
            title="Try it now."
            kicker="Live Demo"
            variant="lavender"
            span={8}
            class="feature-card"
            id="live-demo"
        >
            <p class="feature-desc">Type anything below. Results are processed entirely in your browser using the Rust/WASM engine — 100,000+ products handled in under 10ms.</p>
            <SmoothSearchDemo client:visible />
        </Card>

        <Card title="0.0s" kicker="Server Overhead" variant="white" span={4} class="stat-card">
            <p class="stat-label">Database queries per search</p>
            <p class="feature-desc">Search moves from your server to your customers' browsers. Your hosting costs drop; their experience improves.</p>
        </Card>

        <Card
            title="Your existing store. No changes required."
            kicker="Compatibility"
            variant="blue"
            span={12}
        >
            <div class="woo-inner">
                <p class="feature-desc">Smooth Search slots into your WooCommerce store as a direct replacement for the default search. Your theme, your filters, your attributes — all intact. No template edits, no developer required.</p>
                <ul class="woo-features">
                    <li>Product categories, tags, and custom attributes</li>
                    <li>WooCommerce price and stock filters</li>
                    <li>Any WordPress theme, zero template changes</li>
                    <li>Requires WordPress 5.8+ and WooCommerce 5.0+</li>
                </ul>
            </div>
        </Card>

        <Card
            title="Pre-compiled Efficiency"
            kicker="Developer First"
            variant="black"
            span={12}
            class="footer-card"
        >
            <div class="footer-card-inner">
                <p class="feature-desc">Your product catalog compiles to a lightweight binary, served from CDN. The first search is as fast as the thousandth — no warm-up, no cold start, no per-query server cost.</p>
                <div class="tech-badge">TARGET: WASM32-UNKNOWN</div>
            </div>
        </Card>

        <Card
            title="Common Questions"
            kicker="FAQ"
            description="Have questions? Most answers are here — from install time to indexing limits to how it compares to traditional search."
            variant="lavender"
            span={12}
            class="faq-card"
        >
            <FAQ
                items={faqs}
                hideHeader={true}
            />
        </Card>

        <Footer />
	</div>
</Layout>

<style>
    .hero {
        grid-column: span 12;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 180px);
        position: relative;
        padding: 40px;
        margin-bottom: 60px;
    }

    .hero::after {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: -3%;
        width: 2px;
        background: var(--c-lavender);
        box-shadow:
            0 0 15px 3px rgba(157, 141, 241, 0.5),
            0 0 40px 8px rgba(157, 141, 241, 0.2);
        opacity: 0;
        z-index: 5;
        pointer-events: none;
        animation: lightSweep 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s forwards;
    }

    @keyframes lightSweep {
        0% { left: -3%; opacity: 1; }
        85% { opacity: 0.8; }
        100% { left: 103%; opacity: 0; }
    }

    .hero-content {
        text-align: center;
        max-width: 900px;
        position: relative;
        z-index: 3;
    }

    .hero-title {
        font-family: var(--font-hero);
        font-size: clamp(4rem, 10vw, 7.5rem);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -0.02em;
        margin-bottom: 20px;
        color: var(--c-text-primary);
        opacity: 0;
        animation: revealUp 0.5s ease-out 0.55s forwards,
                   glowPulse 0.4s ease-out 0.95s forwards;
    }

    @keyframes revealUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes glowPulse {
        0%, 100% { text-shadow: none; }
        40% { text-shadow: 0 0 40px rgba(157, 141, 241, 0.2); }
    }

    .hero-title-accent {
        font-family: var(--font-hero);
        font-weight: 800;
        color: var(--c-lavender);
    }

    .compile-status {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
        opacity: 0;
        animation: fadeIn 0.4s ease-out 0.95s forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--c-status-green);
        box-shadow: 0 0 8px var(--c-status-green-glow);
        flex-shrink: 0;
    }

    .status-text {
        font-family: 'SF Mono', 'Monaco', 'Cascadia Code', 'Consolas', monospace;
        font-size: 0.8em;
        font-weight: 400;
        color: var(--c-text-secondary);
        opacity: 0.7;
    }

    .hero-subtitle {
        font-family: var(--font-body);
        font-size: var(--text-xl);
        font-weight: var(--weight-normal);
        line-height: var(--leading-relaxed);
        color: var(--c-text-secondary);
        max-width: 700px;
        margin: 0 auto;
        opacity: 0;
        animation: revealUp 0.4s ease-out 1.15s forwards;
    }

    .hero-actions {
        display: flex;
        align-items: center;
        gap: 24px;
        justify-content: center;
        margin-top: 40px;
        flex-wrap: wrap;
        opacity: 0;
        animation: revealUp 0.4s ease-out 1.35s forwards;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero::after { display: none; }
        .hero-title,
        .compile-status,
        .hero-subtitle,
        .hero-actions {
            animation: none;
            opacity: 1;
            transform: none;
        }
    }

    .hero-cta {
        background: var(--c-primary);
        color: var(--c-primary-inverse);
        padding: 16px 32px;
        border-radius: var(--radius-pill);
        text-decoration: none;
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: var(--weight-semibold);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 15px var(--c-shadow);
        transition: transform 0.3s var(--ease-smooth), box-shadow 0.3s var(--ease-smooth);
    }

    .hero-cta svg {
        transition: transform 0.3s var(--ease-smooth);
    }

    .hero-cta:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 25px var(--c-shadow);
    }

    .hero-cta:hover svg {
        transform: translateX(4px);
    }

    .hero-cta:active {
        transform: scale(1.02) translateY(1px);
    }

    .hero-secondary-cta {
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: var(--weight-medium);
        color: var(--c-text-secondary);
        text-decoration: none;
        transition: color 0.3s var(--ease-smooth);
    }

    .hero-secondary-cta:hover {
        color: var(--c-text-primary);
    }

    .hero-card {
        min-height: 500px;
    }

    .card-title-lg {
        font-family: var(--font-display);
        font-size: var(--text-4xl);
        font-weight: var(--weight-bold);
        line-height: var(--leading-tight);
        letter-spacing: var(--tracking-tight);
    }

    .cta-button {
        margin-top: 32px;
        background: var(--c-primary);
        color: var(--c-primary-inverse);
        padding: 16px 32px;
        border-radius: var(--radius-pill);
        text-decoration: none;
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: var(--weight-semibold);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease, box-shadow 0.3s ease;
        align-self: flex-start;
        box-shadow: 0 4px 15px var(--c-shadow);
    }

    .cta-button:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 25px var(--c-shadow);
    }

    .cta-button:active {
        transform: scale(1.02) translateY(1px);
        box-shadow: 0 2px 10px var(--c-shadow);
    }

    .cta-button svg {
        transition: transform 0.3s ease;
    }

    .cta-button:hover svg {
        transform: translateX(4px);
    }

    .stat-label {
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: var(--weight-medium);
        color: var(--c-text-secondary);
        margin-top: 8px;
    }

    .feature-desc {
        font-family: var(--font-body);
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        margin-top: 12px;
    }

    .footer-card-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .tech-badge {
        font-size: var(--text-xs);
        font-family: 'SF Mono', 'Monaco', 'Cascadia Code', 'Consolas', monospace;
        opacity: 0.6;
        padding: 8px 16px;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 12px;
    }

    .woo-inner {
        display: flex;
        gap: 48px;
        align-items: flex-start;
        width: 100%;
        margin-top: 12px;
    }

    .woo-features {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 280px;
        flex-shrink: 0;
        margin-top: 4px;
    }

    .woo-features li {
        font-family: var(--font-body);
        font-size: var(--text-base);
        line-height: var(--leading-normal);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .woo-features li::before {
        content: '';
        width: 5px;
        height: 5px;
        background: currentColor;
        border-radius: 50%;
        flex-shrink: 0;
        opacity: 0.5;
    }

    .faq-card {
        margin-top: 20px;
    }

    .faq-card :global(.faq-list) {
        margin-top: 24px;
    }

    @media (max-width: 1024px) {
        .hero {
            min-height: calc(100vh - 200px);
            padding: 40px 20px;
            margin-bottom: 50px;
        }

        .woo-inner {
            flex-direction: column;
            gap: 24px;
        }

        .footer-card-inner {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }

        .hero-card {
            min-height: 400px;
        }
    }

    @media (max-width: 640px) {
        .hero {
            min-height: calc(100vh - 160px);
            padding: 60px 24px;
            margin-bottom: 40px;
        }

        .hero-content {
            padding: 0;
        }

        .hero-title {
            font-size: clamp(3rem, 12vw, 5rem);
            margin-bottom: 20px;
        }

        .hero-subtitle {
            padding: 0 10px;
            font-size: var(--text-lg);
        }

        .hero-actions {
            flex-direction: column;
            gap: 16px;
        }

        .hero-cta {
            width: 100%;
            justify-content: center;
        }

        .hero-card {
            min-height: 360px;
        }

        .cta-button {
            padding: 14px 24px;
            width: 100%;
            justify-content: center;
        }

        .tech-badge {
            padding: 6px 12px;
        }
    }

    @media (max-width: 480px) {
        .hero {
            padding: 40px 20px;
            margin-bottom: 32px;
        }

        .hero-title {
            font-size: clamp(2.5rem, 11vw, 4rem);
            margin-bottom: 16px;
        }

        .hero-subtitle {
            font-size: var(--text-base);
        }

        .hero-card {
            min-height: 320px;
        }
    }
</style>
